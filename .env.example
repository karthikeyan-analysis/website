## Vercel / Local environment variables
#
# Copy to `.env` for local dev (never commit `.env`)

# Firebase client (Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK (server-side for /api/*)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key; use \n for line breaks if needed.
FIREBASE_PRIVATE_KEY=
# Recommended on Vercel to avoid PEM newline/quote issues:
# Base64 of the full private key PEM (including BEGIN/END lines).
FIREBASE_PRIVATE_KEY_BASE64=

# Email (recommended: Gmail App Password)
# IMPORTANT: Gmail normal password will fail with "535-5.7.8 BadCredentials".
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
ADMIN_EMAIL=

# Optional
FRONTEND_URL=http://localhost:5173
EMAIL_REPLY_TO=

