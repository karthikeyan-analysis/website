rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == "admin";
    }

    // Exam question images:
    // - readable by any signed-in user (students need to see the question image)
    // - writable only by admins
    match /examTests/{testId}/questions/{questionId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Student profile photos (admin upload; students need read for UI / PDF)
    match /studentPhotos/{studentId}/{name} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}

